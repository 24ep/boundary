# Boundary Mobile App Environment Configuration
# Copy this file to .env and fill in your values
# Variables prefixed with EXPO_PUBLIC_ are automatically bundled by Expo

# ==========================================
# API Configuration
# ==========================================
# Main API endpoint for the mobile app
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# CMS/Content API (if different from main API)
EXPO_PUBLIC_CMS_URL=http://localhost:1337

# ==========================================
# Application Identity
# ==========================================
EXPO_PUBLIC_APP_NAME=Boundary
EXPO_PUBLIC_APP_VERSION=1.0.0
# Multi-tenant application ID (UUID from management dashboard)
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_APP_SLUG=boundary

# ==========================================
# AppKit SDK Configuration
# ==========================================
# These values are often derived from EXPO_PUBLIC_API_URL but can be overridden
# EXPO_PUBLIC_APPKIT_BASE_URL=http://localhost:4000
# EXPO_PUBLIC_APPKIT_APP_ID=boundary-mobile-app

# ==========================================
# Social Authentication (Optional)
# ==========================================
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id_here
EXPO_PUBLIC_APPLE_CLIENT_ID=your_apple_client_id_here

# ==========================================
# Push Notifications & Analytics
# ==========================================
EXPO_PUBLIC_PUSH_NOTIFICATION_KEY=your_expo_push_key_here
EXPO_PUBLIC_ANALYTICS_KEY=
EXPO_PUBLIC_ERROR_REPORTING_KEY=

# ==========================================
# Feature Flags
# ==========================================
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=false
EXPO_PUBLIC_ENABLE_LOCATION_SERVICES=true
