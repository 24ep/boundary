# Boundary Project Master Environment Configuration
# This file serves as a reference for all environment variables used across the monorepo.
# For specific services, refer to their respective .env.example files.

# ==========================================
# WORKSPACE TEMPLATES
# ==========================================
# Mobile Backend:  bondary-backend/.env.example
# Mobile App:      boundary-app/.env.example
# AppKit Server:   appkit/.env.example

# ==========================================
# CORE INFRASTRUCTURE (Shared)
# ==========================================
# Primary Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boundary?schema=public"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Object Storage (S3 Compatible)
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=boundary-storage
S3_ENDPOINT=http://localhost:9000

# ==========================================
# MOBILE APP (EXPO)
# ==========================================
# Set these in boundary-app/.env
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_APP_NAME=Boundary
EXPO_PUBLIC_APP_ID=your-app-id

# ==========================================
# APPKIT SERVER
# ==========================================
# Set these in appkit/.env
# PORT=3002
# NEXT_PUBLIC_SITE_URL=http://localhost:3002