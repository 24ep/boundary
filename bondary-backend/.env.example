# Boundary Mobile Backend Server Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=4000
MOBILE_PORT=4000
HOST=0.0.0.0

# Railway/Proxy Configuration
TRUST_PROXY=true
CORS_ORIGIN=*

# ==========================================
# Database Configuration
# ==========================================
# DATABASE_URL is the preferred connection method for both Prisma and legacy pool
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boundary?schema=public"

# ==========================================
# Authentication & Security
# ==========================================
# JWT secrets (Min length: 32 chars)
JWT_SECRET=boundary-mobile-server-secret-key-32chars-minimum
JWT_REFRESH_SECRET=boundary-refresh-dev-secret-key-32chars-minimum
JWT_EXPIRES_IN=7d

# ==========================================
# Redis Configuration (Optional)
# ==========================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# Object Storage (S3 Compatible - e.g., MinIO or AWS)
# ==========================================
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=boundary-storage
S3_ENDPOINT=http://localhost:9000

# ==========================================
# Monitoring & Logging
# ==========================================
